# DevBrainTeaching environment template.
#
# Copy this file to .env for local use:
#   cp .env.example .env
#
# Keep real secrets only in .env. This example file should stay safe to commit.

# Optional: point DevBrainTeaching at a specific gbrain binary.
# Leave unset to use the global `gbrain` on PATH.
# GBRAIN_BIN=/Users/frankqdwang/Agents/DevBrain/src/cli.ts

# Required for `bun run jina-smoke` and for `bun run jina-proxy` when the
# proxy itself owns the Jina credential. Do not commit a real value here.
JINA_API_KEY=

# Jina endpoint override. Leave unset for https://api.jina.ai/v1/embeddings.
# Use this only if Jina changes the endpoint or you intentionally route
# through another compatible gateway.
# JINA_BASE_URL=https://api.jina.ai/v1

# Jina model and vector width used by the local proxy.
# Match the existing gbrain brain's embedding width. The current local brain
# expects 1536 dimensions.
JINA_EMBEDDING_MODEL=jina-embeddings-v4
JINA_EMBEDDING_DIMENSIONS=1536

# Optional Jina task/adaptor hint. Leave unset until we intentionally choose
# an asymmetric retrieval mode for gbrain indexing/querying.
# JINA_EMBEDDING_TASK=

# Local proxy listen address.
JINA_PROXY_HOST=127.0.0.1
JINA_PROXY_PORT=8787

# gbrain route through its existing LiteLLM-compatible OpenAI endpoint.
# Start the proxy first with `bun run jina-proxy`, then run gbrain commands
# from a shell where these values are exported.
LITELLM_BASE_URL=http://127.0.0.1:8787/v1
GBRAIN_EMBEDDING_MODEL=litellm:jina-embeddings-v4
GBRAIN_EMBEDDING_DIMENSIONS=1536

# Usually leave LITELLM_API_KEY unset: the proxy uses JINA_API_KEY from its
# own environment. Set this only if you want gbrain to pass the key through
# Authorization: Bearer <key> instead of letting the proxy read JINA_API_KEY.
# LITELLM_API_KEY=

# DeepSeek LLM route for upstream gbrain dream. DeepSeek provides an
# Anthropic-compatible endpoint, but upstream gbrain's dream judge/subagent
# currently calls the Anthropic SDK directly. Keep the real key only in .env.
DEEPSEEK_API_KEY=
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# Same value as DEEPSEEK_API_KEY while upstream gbrain reads ANTHROPIC_API_KEY.
ANTHROPIC_API_KEY=
# Model intent for the repo-local gbrain config:
# - Flash is the cheaper 1M-context verdict/classification model.
# - Pro is the stronger 1M-context synthesis model.
DEEPSEEK_DREAM_VERDICT_MODEL=deepseek-v4-flash
DEEPSEEK_DREAM_SYNTHESIS_MODEL=deepseek-v4-pro

# Repo-local gbrain v5 runtime. This is separate from the global ~/.gbrain
# runtime and from any other running pgvector containers. Keep the real
# Postgres password only in .env; this template must stay safe to commit.
GBRAIN_V5_POSTGRES_PASSWORD=
GBRAIN_V5_POSTGRES_HOST=127.0.0.1
GBRAIN_V5_POSTGRES_PORT=55433
GBRAIN_V5_POSTGRES_DB=devbrainteaching_gbrain_v5
GBRAIN_V5_POSTGRES_USER=gbrain_v5

JINA_V5_MODEL_ID=jinaai/jina-embeddings-v5-text-small-mlx
# Optional local checkpoint path. Leave unset for .devbrain-teaching/models/jina-v5-text-small-mlx.
# JINA_V5_MODEL_DIR=.devbrain-teaching/models/jina-v5-text-small-mlx
JINA_V5_EMBEDDING_MODEL=jina-embeddings-v5-text-small
JINA_V5_EMBEDDING_DIMENSIONS=1024
JINA_V5_TASK=retrieval
JINA_V5_DOCUMENT_TASK_TYPE=retrieval.passage
JINA_V5_QUERY_TASK_TYPE=retrieval.query
JINA_V5_PROXY_HOST=127.0.0.1
JINA_V5_PROXY_PORT=8797
