{
  "name": "devbrain-teaching",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Teaching episode output layer for a local gbrain installation.",
  "bin": {
    "devbrain-teaching": "src/index.ts"
  },
  "scripts": {
    "doctor": "bun run src/index.ts doctor",
    "candidates": "bun run src/index.ts candidates",
    "jina-proxy": "bun run src/index.ts jina-proxy",
    "jina-smoke": "bun run src/index.ts jina-smoke",
    "jina-v5-mlx-server": ".devbrain-teaching/venv/bin/python scripts/jina_v5_mlx_server.py",
    "jina-v5-setup": "bun run src/index.ts jina-v5-setup",
    "jina-v5-service": "bun run src/index.ts jina-v5-service",
    "gbrain-v5-env": "bun run src/index.ts gbrain-v5-env",
    "gbrain-v5-check": "bun run src/index.ts gbrain-v5-check",
    "gbrain-v5-init": "bun run src/index.ts gbrain-v5-init",
    "codex-collect": "bun run src/index.ts codex-collect",
    "gbrain-dream-check": "bun run src/index.ts gbrain-dream-check",
    "codex-dream-cycle": "bun run src/index.ts codex-dream-cycle",
    "codex-ingest": "bun run src/index.ts codex-ingest",
    "test": "bun test"
  },
  "engines": {
    "bun": ">=1.3.10"
  }
}
